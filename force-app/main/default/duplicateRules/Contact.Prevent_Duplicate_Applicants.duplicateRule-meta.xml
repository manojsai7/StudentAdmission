<?xml version="1.0" encoding="UTF-8"?>
<DuplicateRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionOnInsert>Block</actionOnInsert>
    <actionOnUpdate>Block</actionOnUpdate>
    <alertText>Applicant already exists</alertText>
    <description>Prevent duplicate applicants based on name and email.</description>
    <duplicateRuleFilter>
        <booleanFilter>1</booleanFilter>
        <duplicateRuleFilterItems>
            <field>Email</field>
            <operation>notEqual</operation>
            <value></value>
        </duplicateRuleFilterItems>
    </duplicateRuleFilter>
    <isActive>true</isActive>
    <masterLabel>Prevent Duplicate Applicants</masterLabel>
    <matchingRule>Contact.Applicant_Matching</matchingRule>
    <operationsOnInsert>
        <allowSave>false</allowSave>
    </operationsOnInsert>
    <operationsOnUpdate>
        <allowSave>false</allowSave>
    </operationsOnUpdate>
    <securityOption>BypassSharing</securityOption>
</DuplicateRule>
