<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <submitter>owner</submitter>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>Application__c.Name</approvalPageFields>
    <approvalPageFields>Application__c.Applicant__c</approvalPageFields>
    <approvalPageFields>Application__c.Program__c</approvalPageFields>
    <description>Admission application approval workflow.</description>
    <entryCriteriaItems>
        <field>Status__c</field>
        <operation>equals</operation>
        <value>Submitted</value>
    </entryCriteriaItems>
    <finalApprovalActions>
        <action>
            <name>Final_Approve_Status_Update</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalActions>
        <action>
            <name>Final_Approve_Decision_Date_Update</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalActions>
        <action>
            <name>Alert_Decision</name>
            <type>EmailAlert</type>
        </action>
    </finalApprovalActions>
    <finalRejectionActions>
        <action>
            <name>Final_Reject_Status_Update</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionActions>
        <action>
            <name>Final_Reject_Decision_Date_Update</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionActions>
        <action>
            <name>Alert_Decision</name>
            <type>EmailAlert</type>
        </action>
    </finalRejectionActions>
    <label>Application Approval Process</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
    </nextAutomatedApprover>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
    <steps>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>Admission_Officer</name>
                <type>role</type>
            </approver>
        </assignedApprover>
        <entryCriteriaItems>
            <field>Status__c</field>
            <operation>equals</operation>
            <value>Submitted</value>
        </entryCriteriaItems>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>Admission Officer Review</label>
        <name>Admission_Officer_Review</name>
    </steps>
</ApprovalProcess>
