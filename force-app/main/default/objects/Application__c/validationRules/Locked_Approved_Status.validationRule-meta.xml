<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(PRIORVALUE(Status__c), "Approved") &amp;&amp; ISPICKVAL(Status__c, "Rejected")</errorConditionFormula>
    <errorDisplayField>Status__c</errorDisplayField>
    <errorMessage>Cannot change an Approved application to Rejected.</errorMessage>
</ValidationRule>
