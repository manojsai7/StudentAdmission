<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <errorConditionFormula>NOT(ISBLANK(Decision_Date__c)) &amp;&amp; Decision_Date__c &lt; Submission_Date__c</errorConditionFormula>
    <errorDisplayField>Decision_Date__c</errorDisplayField>
    <errorMessage>Decision Date must be after Submission Date.</errorMessage>
</ValidationRule>
