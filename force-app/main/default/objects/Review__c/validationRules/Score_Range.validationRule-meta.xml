<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <errorConditionFormula>OR(Score__c &lt; 0, Score__c &gt; 100)</errorConditionFormula>
    <errorDisplayField>Score__c</errorDisplayField>
    <errorMessage>Score must be between 0 and 100.</errorMessage>
</ValidationRule>
