    <description>Decision outcome notification for applicants.</description>
    <encodingKey>UTF-8</encodingKey>
    <name>App Decision</name>
    <style>none</style>
    <subject>Decision on your Application – {!Application__c.Name}</subject>
    <type>custom</type>
